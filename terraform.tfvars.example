tenant_id               = "00000000-0000-0000-0000-000000000000"
root_management_group_id = "00000000-0000-0000-0000-000000000000"
organization_name       = "contoso"

management_subscription_id   = "11111111-1111-1111-1111-111111111111"
connectivity_subscription_id = "22222222-2222-2222-2222-222222222222"
identity_subscription_id     = "33333333-3333-3333-3333-333333333333"

location          = "eastus2"
allowed_locations = ["eastus2", "centralus"]

